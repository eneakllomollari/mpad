{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for mdview",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "fs:allow-watch",
    "cli:default",
    "dialog:default",
    "core:window:allow-create",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:window:allow-theme",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/tmp/**" },
        { "path": "$RESOURCE/**" }
      ]
    }
  ]
}
