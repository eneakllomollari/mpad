{
  "name": "mpad",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .hooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && oxlint --deny-warnings src/ && knip",
    "check:rust": "cd src-tauri && cargo check && cargo test && cargo clippy -- -D warnings -W clippy::perf -W clippy::large_enum_variant -W clippy::needless_collect",
    "oxlint": "oxlint --deny-warnings src/",
    "knip": "knip",
    "test": "vitest run --exclude 'tests/*.perf.test.ts' --exclude 'tests/perf.test.ts'",
    "test:perf": "vitest run tests/perf.test.ts",
    "test:coverage": "vitest run --exclude 'tests/*.perf.test.ts' --exclude 'tests/perf.test.ts' --coverage",
    "check:all": "bun run check && bun run test:coverage && bun run test:perf && bun run check:rust",
    "preview": "vite preview",
    "reinstall": "bunx tauri build && cp -r src-tauri/target/release/bundle/macos/mpad.app /Applications/",
    "reinstall:remote": "./install.sh"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "framer-motion": "^12.38.0",
    "lowlight": "^3.3.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "knip": "^5.88.1",
    "oxlint": "^1.58.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "smol-toml": ">=1.6.1",
    "brace-expansion": "1.1.13",
    "undici": "~7.24.0",
    "yaml": ">=2.8.3",
    "flatted": ">=3.4.0",
    "picomatch": ">=4.0.4"
  }
}
